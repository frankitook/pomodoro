{
  "name": "pomodoro-plant",
  "version": "1.0.0",
  "author": "Franco",
  "description": "A cozy Pomodoro timer with a growing plant",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.pomodoro.plant",
    "mac": {
      "category": "public.app-category.utilities",
